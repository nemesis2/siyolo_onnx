# .env.example
# siyolo -- Simple YOLO Inference Server (ONNX Version)
# Copy this file to .env and edit for your deployment.

# Network
SERVER_PORT=32168

# Model
SERVER_MODEL=yolo26x.onnx
MODELS_DIR=./models

# Inference
MINIMUM_CONFIDENCE=0.65
IMG_SZ_X=1152
IMG_SZ_Y=640

# TensorRT (GPU profile only)
TRT_FP16=1
TRT_CACHE_DIR=        # leave empty to use MODELS_DIR